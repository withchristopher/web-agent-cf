{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "web-agent-cf",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-13",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOM",
        "class_name": "DemoRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DemoRoom"]
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "web-agent-cf-demo-db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "web-agent-cf-demo-receipts"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "EVENTS_QUEUE",
        "queue": "web-agent-cf-events"
      }
    ],
    "consumers": [
      {
        "queue": "web-agent-cf-events",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3
      }
    ]
  },
  "ai": {
    "binding": "AI"
  }
}
